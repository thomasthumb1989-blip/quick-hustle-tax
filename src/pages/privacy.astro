---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';
---

<BaseLayout title="Privacy Policy">
  <div class="max-w-3xl mx-auto prose prose-slate dark:prose-invert">
    <h1>Privacy Policy</h1>
    <p><em>Last updated: May 2026</em></p>

    <h2>Who we are</h2>
    <p>{SITE.name} is a UK-based website providing free tax calculation tools.</p>

    <h2>What data we collect</h2>
    <p>We do not collect personal data through our calculators. All calculations are performed in your browser — no data is sent to our servers.</p>

    <h2>Analytics</h2>
    <p>With your consent, we use Google Analytics 4 and Microsoft Clarity to understand how visitors use our tools. These are only loaded after you accept cookies.</p>
    <p>Cloudflare Web Analytics is used without cookies and does not track individual users.</p>

    <h2>Cookies</h2>
    <p>See our <a href="/cookies">Cookie Policy</a> for details on what cookies we use and why.</p>

    <h2>Advertising</h2>
    <p>We may display ads via Google AdSense. Google may use cookies to serve personalised ads based on your browsing history. You can opt out at <a href="https://adssettings.google.com" target="_blank" rel="noopener">Google Ad Settings</a>.</p>

    <h2>Your rights under UK GDPR</h2>
    <ul>
      <li>Right to access your data</li>
      <li>Right to erasure</li>
      <li>Right to object to processing</li>
      <li>Right to data portability</li>
    </ul>

    <h2>Contact</h2>
    <p>For privacy inquiries, contact us at privacy@uktaxtools.co.uk.</p>
  </div>
</BaseLayout>
