---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Cookie Policy">
  <div class="max-w-3xl mx-auto prose prose-slate dark:prose-invert">
    <h1>Cookie Policy</h1>
    <p><em>Last updated: May 2026</em></p>

    <h2>What are cookies?</h2>
    <p>Cookies are small text files stored on your device when you visit websites.</p>

    <h2>Cookies we use</h2>

    <h3>Strictly necessary</h3>
    <table>
      <thead><tr><th>Cookie</th><th>Purpose</th><th>Duration</th></tr></thead>
      <tbody>
        <tr><td>cookie-consent</td><td>Stores your cookie preference</td><td>1 year</td></tr>
        <tr><td>theme</td><td>Stores light/dark mode preference</td><td>Persistent</td></tr>
      </tbody>
    </table>

    <h3>Analytics (consent required)</h3>
    <table>
      <thead><tr><th>Cookie</th><th>Provider</th><th>Purpose</th></tr></thead>
      <tbody>
        <tr><td>_ga, _ga_*</td><td>Google Analytics</td><td>Distinguish users, measure site usage</td></tr>
        <tr><td>_clck, _clsk</td><td>Microsoft Clarity</td><td>Session recording and heatmaps</td></tr>
      </tbody>
    </table>

    <h3>Advertising (consent required)</h3>
    <table>
      <thead><tr><th>Cookie</th><th>Provider</th><th>Purpose</th></tr></thead>
      <tbody>
        <tr><td>Various</td><td>Google AdSense</td><td>Serve and measure ads</td></tr>
      </tbody>
    </table>

    <h2>Managing cookies</h2>
    <p>You can change your preference at any time by clearing your browser's localStorage and refreshing the page.</p>
  </div>
</BaseLayout>
