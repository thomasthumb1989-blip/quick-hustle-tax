---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Side-Hustle Tax Calculator" description="Calculate how much tax you owe on your side income alongside your main PAYE job. UK tax year 2025/26.">
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold mb-2">Side-Hustle Tax Calculator</h1>
    <p class="text-[var(--text-secondary)] mb-8">
      Calculate tax owed on your side income when you're already employed (PAYE). UK 2025/26 tax year.
    </p>

    <!-- React calculator island will go here -->
    <div id="calculator-placeholder" class="rounded-xl border-2 border-dashed border-[var(--border)] p-12 text-center text-[var(--text-muted)]">
      <p class="text-lg">Calculator widget loading here</p>
      <p class="text-sm mt-2">React island — built in next prompt</p>
    </div>

    <!-- MDX content will render below -->
    <section class="mt-12 prose prose-slate dark:prose-invert max-w-none">
      <h2>How Side-Hustle Tax Works in the UK</h2>
      <p>Content placeholder — MDX will provide detailed explanation, FAQs, and examples.</p>
    </section>

    <p class="mt-8 text-xs text-[var(--text-muted)] border-t border-[var(--border)] pt-4">
      <strong>Disclaimer:</strong> This calculator provides estimates only and does not constitute financial advice.
      Always consult HMRC or a qualified accountant for your specific situation.
    </p>
  </div>
</BaseLayout>
