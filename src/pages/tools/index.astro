---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/ui/Card.astro';

const tools = [
  { title: 'Take-Home Pay Calculator', href: '/take-home-pay-calculator/', icon: '💷' },
  { title: 'Side-Hustle Tax Calculator', href: '/side-hustle-tax-calculator/', icon: '💰' },
  { title: 'Sole Trader vs Ltd', href: '/sole-trader-vs-ltd-calculator/', icon: '⚖️' },
  { title: 'Trading Allowance Checker', href: '/trading-allowance-checker/', icon: '✅' },
  { title: 'Dividend Tax Calculator', href: '/dividend-tax-calculator/', icon: '📊' },
  { title: 'Self-Assessment Deadline Checker', href: '/self-assessment-deadline-checker/', icon: '📅' },
];
---

<BaseLayout title="All Tax Tools" description="Free UK tax calculators for side-hustlers, sole traders, and freelancers. 2026/27 rates, instant results, no sign-up.">
  <h1 class="text-3xl font-bold mb-2">All Tools</h1>
  <p class="text-[var(--text-secondary)] mb-8">Free UK tax calculators and checkers for the {import.meta.env.PUBLIC_TAX_YEAR || '2026/27'} tax year.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {tools.map((tool) => (
      <a href={tool.href} class="group">
        <Card class="h-full hover:border-primary-500/50 hover:shadow-md transition-all duration-200">
          <span class="text-2xl">{tool.icon}</span>
          <h2 class="text-lg font-semibold mt-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
            {tool.title}
          </h2>
        </Card>
      </a>
    ))}
  </div>
</BaseLayout>
