---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/ui/Card.astro';

const tools = [
  { title: 'Take-Home Pay Calculator', description: 'See your actual take-home after tax, NI, and deductions.', href: '/take-home-pay-calculator/', icon: '💷' },
  { title: 'Side-Hustle Tax Calculator', description: 'Calculate tax on your side income alongside PAYE employment.', href: '/side-hustle-tax-calculator/', icon: '💰' },
  { title: 'Sole Trader vs Ltd', description: 'Compare tax efficiency between sole trader and limited company.', href: '/sole-trader-vs-ltd-calculator/', icon: '⚖️' },
  { title: 'Trading Allowance Checker', description: 'Check if you qualify for the £1,000 trading allowance.', href: '/trading-allowance-checker/', icon: '✅' },
  { title: 'Dividend Tax Calculator', description: 'Calculate dividend tax at the new 10.75% and 35.75% rates.', href: '/dividend-tax-calculator/', icon: '📊' },
  { title: 'Self-Assessment Deadline Checker', description: 'Check your deadlines and calculate late filing/payment penalties.', href: '/self-assessment-deadline-checker/', icon: '📅' },
  { title: 'Platform Seller Reporting Checker', description: 'Check if HMRC knows about your eBay, Etsy, Vinted or Amazon sales — and whether you owe tax.', href: '/platform-seller-reporting-checker/', icon: '🛒' },
  { title: 'Side-Hustle Growth Tracker', description: 'Calculate how many items you need to sell to hit your income target, after real platform fees.', href: '/side-hustle-growth-tracker/', icon: '📈' },
];
---

<BaseLayout title="All Tax Tools" description="Free UK tax calculators for side-hustlers, sole traders, and freelancers. 2026/27 rates, instant results, no sign-up.">
  <h1 class="text-3xl font-bold mb-2">All Tools</h1>
  <p class="text-[var(--text-secondary)] mb-8">Free UK tax calculators and checkers for the {import.meta.env.PUBLIC_TAX_YEAR || '2026/27'} tax year.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    {tools.map((tool) => (
      <a href={tool.href} class="group">
        <Card class="h-full hover:border-primary-500/50 hover:shadow-md transition-all duration-200">
          <span class="text-2xl">{tool.icon}</span>
          <h2 class="text-lg font-semibold mt-2 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
            {tool.title}
          </h2>
          <p class="text-sm text-[var(--text-secondary)] mt-1">{tool.description}</p>
        </Card>
      </a>
    ))}
  </div>
</BaseLayout>
