---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="All Tax Tools" description="Free UK tax calculators for side-hustlers, sole traders, and freelancers. 2025/26 rates, instant results, no sign-up.">
  <h1 class="text-3xl font-bold mb-2">All Tools</h1>
  <p class="text-[var(--text-secondary)] mb-8">Free UK tax calculators and checkers for the {import.meta.env.PUBLIC_TAX_YEAR || '2025/26'} tax year.</p>
  <p class="text-[var(--text-muted)]">Tools coming soon. Check back shortly.</p>
</BaseLayout>
