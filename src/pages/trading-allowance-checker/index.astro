---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config/site';
import { breadcrumbSchema } from '../../lib/seo/schema';

const pageTitle = 'UK Trading Allowance Checker 2025/26';
const pageDescription = 'Check if you qualify for the £1,000 trading allowance and whether you need to register for Self Assessment. Free, instant result.';

const breadcrumbs = breadcrumbSchema([
  { name: 'Home', url: SITE.url },
  { name: 'Tools', url: `${SITE.url}/tools/` },
  { name: 'Trading Allowance Checker', url: `${SITE.url}/trading-allowance-checker/` },
]);
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />

  <div class="max-w-4xl mx-auto">
    <nav class="text-sm text-[var(--text-muted)] mb-6" aria-label="Breadcrumb">
      <ol class="flex items-center gap-1.5">
        <li><a href="/" class="hover:text-primary-500">Home</a></li>
        <li>/</li>
        <li><a href="/tools" class="hover:text-primary-500">Tools</a></li>
        <li>/</li>
        <li class="text-[var(--text-primary)]">Trading Allowance Checker</li>
      </ol>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">
        Trading Allowance Checker
        <span class="text-lg font-normal text-[var(--text-muted)] ml-2">(2025/26)</span>
      </h1>
      <p class="text-lg text-[var(--text-secondary)] mt-2">
        Do you need to tell HMRC about your side income? Check if the £1,000 trading allowance covers you.
      </p>
    </header>

    <div class="rounded-xl border-2 border-dashed border-[var(--border)] p-12 text-center">
      <p class="text-2xl mb-2">✅</p>
      <p class="text-lg font-semibold text-[var(--text-primary)]">Coming Soon</p>
      <p class="text-sm text-[var(--text-muted)] mt-2 max-w-md mx-auto">
        This checker is being built right now. In the meantime, try our
        <a href="/side-hustle-tax-calculator/" class="text-primary-600 dark:text-primary-400 hover:underline">Side-Hustle Tax Calculator</a>
        which includes the trading allowance automatically.
      </p>
    </div>

    <footer class="mt-12 pt-4 border-t border-[var(--border)]">
      <p class="text-xs text-[var(--text-muted)]">
        Tax year {SITE.taxYear} · England, Wales & Northern Ireland rates
      </p>
    </footer>
  </div>
</BaseLayout>
