---
import BaseLayout from './BaseLayout.astro';
import { SITE } from '../config/site';

interface Props {
  title: string;
  description: string;
  lastUpdated?: string;
}

const { title, description, lastUpdated } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="max-w-3xl mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">{title}</h1>
      <p class="text-lg text-[var(--text-secondary)] mt-2">{description}</p>
    </header>

    <slot />

    <footer class="mt-12 pt-4 border-t border-[var(--border)] space-y-2">
      <p class="text-xs text-[var(--text-muted)]">
        <strong>Disclaimer:</strong> This tool provides estimates only and does not constitute financial advice.
        Always consult HMRC or a qualified accountant for your specific situation.
      </p>
      {lastUpdated && (
        <p class="text-xs text-[var(--text-muted)]">
          Last updated: {lastUpdated} &middot; Tax year {SITE.taxYear}
        </p>
      )}
    </footer>
  </div>
</BaseLayout>
