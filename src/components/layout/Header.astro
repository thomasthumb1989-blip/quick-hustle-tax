---
import { SITE } from '../../config/site';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="sticky top-0 z-50 border-b border-[var(--border)] bg-[var(--bg-primary)]/95 backdrop-blur-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href="/" class="text-lg sm:text-2xl uppercase tracking-tight hover:opacity-80 transition-opacity text-[#0a1628] dark:text-white" style="font-family: 'Montserrat', sans-serif; font-weight: 800;">
      Quick Hustle Tax
    </a>
    <nav class="flex items-center gap-6">
      <a href="/tools" class="text-sm font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors">
        Tools
      </a>
      <ThemeToggle />
    </nav>
  </div>
</header>
