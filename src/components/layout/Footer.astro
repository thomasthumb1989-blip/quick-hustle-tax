---
import { SITE } from '../../config/site';
---

<footer class="border-t border-[var(--border)] bg-[var(--bg-secondary)] mt-auto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <p class="font-bold text-[var(--text-primary)]">{SITE.name}</p>
        <p class="text-sm text-[var(--text-muted)] mt-1">Free UK tax calculators and checkers for side-hustlers, sole traders, and freelancers.</p>
      </div>
      <div>
        <p class="font-semibold text-sm text-[var(--text-primary)] mb-2">Tools</p>
        <ul class="space-y-1 text-sm text-[var(--text-secondary)]">
          <li><a href="/side-hustle-tax-calculator/" class="hover:text-primary-500">Side-Hustle Tax Calculator</a></li>
          <li><a href="/take-home-pay-calculator/" class="hover:text-primary-500">Take-Home Pay Calculator</a></li>
          <li><a href="/sole-trader-vs-ltd-calculator/" class="hover:text-primary-500">Sole Trader vs Ltd</a></li>
          <li><a href="/trading-allowance-checker/" class="hover:text-primary-500">Trading Allowance Checker</a></li>
          <li><a href="/dividend-tax-calculator/" class="hover:text-primary-500">Dividend Tax Calculator</a></li>
          <li><a href="/self-assessment-deadline-checker/" class="hover:text-primary-500">Deadline & Penalty Checker</a></li>
          <li><a href="/platform-seller-reporting-checker/" class="hover:text-primary-500">Platform Seller Checker</a></li>
          <li><a href="/side-hustle-growth-tracker/" class="hover:text-primary-500">Growth Tracker</a></li>
        </ul>
      </div>
      <div>
        <p class="font-semibold text-sm text-[var(--text-primary)] mb-2">About & Legal</p>
        <ul class="space-y-1 text-sm text-[var(--text-secondary)]">
          <li><a href="/about/" class="hover:text-primary-500">About</a></li>
          <li><a href="/contact/" class="hover:text-primary-500">Contact</a></li>
          <li><a href="/privacy/" class="hover:text-primary-500">Privacy Policy</a></li>
          <li><a href="/cookies/" class="hover:text-primary-500">Cookie Policy</a></li>
          <li><a href="/disclaimer/" class="hover:text-primary-500">Disclaimer & Terms</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-8 pt-4 border-t border-[var(--border)] text-center text-xs text-[var(--text-muted)]">
      <p>&copy; {new Date().getFullYear()} {SITE.name}. Not financial advice. Tax year {SITE.taxYear}.</p>
    </div>
  </div>
</footer>
