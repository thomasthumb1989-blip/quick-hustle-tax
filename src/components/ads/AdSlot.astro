---
import { MONETISATION } from '../../config/site';

interface Props {
  slot: string;
  format?: 'auto' | 'rectangle' | 'horizontal' | 'vertical';
  className?: string;
}

const { slot, format = 'auto', className = '' } = Astro.props;
---

{MONETISATION.adsenseEnabled && (
  <div class={`ad-slot my-6 flex justify-center ${className}`}>
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={MONETISATION.adsenseClientId}
      data-ad-slot={slot}
      data-ad-format={format}
      data-full-width-responsive="true"
    ></ins>
  </div>
)}
